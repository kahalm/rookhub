###############################################################################
# RookHub full-stack deployment
#
# 1. Clone:           git clone https://github.com/kahalm/rookhub.git && cd rookhub
# 2. Copy this file:  cp compose.yml.example compose.yml
# 3. Create .env (see below) and adjust values
# 4. Start:           docker compose up -d
#
# Required .env variables:
#   JWT_KEY=<min-32-char-secret-for-jwt-signing>
#
# Optional .env overrides (defaults shown):
#   MYSQL_ROOT_PASSWORD=rootpassword
#   CRAWLER_DB_USER=chessresults
#   CRAWLER_DB_PASSWORD=chessresults
#   ROOKHUB_DB_USER=rookhub
#   ROOKHUB_DB_PASSWORD=rookhub_secret
#   FRONTEND_PORT=8085
#   API_PORT=5001
#   DB_PORT=3307
#
# Ports:
#   ${FRONTEND_PORT}  -> Frontend (nginx)
#   ${API_PORT}        -> RookHub API
#   ${DB_PORT}         -> MariaDB
###############################################################################

services:

  # ── Shared MariaDB ─────────────────────────────────────────────────────────
  mariadb:
    image: mariadb:11
    container_name: rookhub-mariadb
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD:-rootpassword}
    ports:
      - "${DB_PORT:-3307}:3306"
    volumes:
      - mariadb-data:/var/lib/mysql
      - ./init-db.sql:/docker-entrypoint-initdb.d/init-db.sql:ro
    command: --character-set-server=utf8mb4 --collation-server=utf8mb4_unicode_ci
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ── ChessResults Crawler ──────────────────────────────────────────────────
  crawler:
    image: ghcr.io/kahalm/rookhub-crawler:latest
    container_name: rookhub-crawler
    restart: unless-stopped
    depends_on:
      mariadb:
        condition: service_healthy
    environment:
      ConnectionStrings__DefaultConnection: "Server=mariadb;Port=3306;Database=chessresults;User=${CRAWLER_DB_USER:-chessresults};Password=${CRAWLER_DB_PASSWORD:-chessresults};"
      ASPNETCORE_ENVIRONMENT: Production

  # ── RookHub API ────────────────────────────────────────────────────────────
  api:
    image: ghcr.io/kahalm/rookhub-api:latest
    container_name: rookhub-api
    restart: unless-stopped
    ports:
      - "${API_PORT:-5001}:8080"
    depends_on:
      mariadb:
        condition: service_healthy
      crawler:
        condition: service_started
    environment:
      ConnectionStrings__DefaultConnection: "Server=mariadb;Port=3306;Database=rookhub;User=${ROOKHUB_DB_USER:-rookhub};Password=${ROOKHUB_DB_PASSWORD:-rookhub_secret};"
      Jwt__Key: ${JWT_KEY:?JWT_KEY must be set in .env or environment}
      Jwt__Issuer: ${JWT_ISSUER:-RookHub}
      Jwt__Audience: ${JWT_AUDIENCE:-RookHub}
      Crawler__BaseUrl: http://crawler:8080
      ASPNETCORE_ENVIRONMENT: Production

  # ── Frontend (Angular + nginx) ─────────────────────────────────────────────
  frontend:
    image: ghcr.io/kahalm/rookhub-frontend:latest
    container_name: rookhub-frontend
    restart: unless-stopped
    ports:
      - "${FRONTEND_PORT:-8085}:80"
    depends_on:
      - api

volumes:
  mariadb-data:
