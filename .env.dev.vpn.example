# RookHub Dev-VPN Environment (pre-built ghcr.io Images)
# docker compose -f compose.dev.vpn.yml --env-file .env.dev.vpn up -d
#
# WICHTIG: Diese Variante laeuft typischerweise PARALLEL zum Prod-Stack
# (compose.vpn.yml / .env.vpn) auf demselben Host. Deshalb MUESSEN sich
# ALLE Host-Ports und ALLE Bind-Pfade vom Prod-Stack unterscheiden — sonst
# kollidieren die Host-Ports bzw. das ES-Datenverzeichnis (node.lock), und
# Elasticsearch/Kibana/API/Frontend starten nicht.

# Database (eigene Werte setzen!)
MARIADB_ROOT_PASSWORD=change_me
CRAWLER_DB_NAME=chessresults
CRAWLER_DB_USER=chessresults
CRAWLER_DB_PASSWORD=change_me
ROOKHUB_DB_NAME=rookhub
ROOKHUB_DB_USER=rookhub
ROOKHUB_DB_PASSWORD=change_me

# JWT (min. 32 Zeichen)
JWT_KEY=change_me_to_a_secure_key_at_least_32_chars
JWT_ISSUER=RookHub
JWT_AUDIENCE=RookHub

# Admin-Account (wird beim Start angelegt/aktualisiert)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Crawler API Key (gleicher Wert in Crawler + RookHub API)
CRAWLER_API_KEY=change_me_to_a_secure_key

# Discord-Verknuepfung: HMAC-Secret fuer signierte Link-Tokens. MUSS exakt mit dem
# schach-bot (ROOKHUB_LINK_SECRET) uebereinstimmen. Leer lassen -> Feature inaktiv.
DISCORD_LINK_SECRET=change_me_shared_with_schach_bot

# Schach-Bot Stats-Endpoint (/api/bot/player-progress): HMAC-Secret, mit dem der Bot
# den Trainings-/Puzzle-Fortschritt verknuepfter Spieler fuer den Motivations-DM liest.
# MUSS exakt mit dem schach-bot (ROOKHUB_STATS_SECRET) uebereinstimmen. Leer -> Endpoint aus.
SCHACH_BOT_STATS_SECRET=change_me_shared_with_schach_bot

# App
ASPNETCORE_ENVIRONMENT=Development

# Host-Ports — dev-eigene Werte, NICHT mit Prod (5001/8086/3307/9202/5601) kollidieren!
API_PORT=5002
FRONTEND_PORT=8087
DB_EXTERNAL_PORT=3309
ES_PORT=9201
KIBANA_PORT=5602
# Admin-UI: Link zur passenden Kibana/ES-Konsole DIESER Umgebung (Admin-Header).
# Leer lassen -> Link bleibt versteckt. Dev-Kibana (eigener Port, NICHT 5601):
KIBANA_URL=http://10.24.13.6:5602

# Bind-Pfade — dev-eigene Verzeichnisse, NICHT die Prod-Pfade (/srv/config/elasticsearch,
# /srv/config/rookhub/...) verwenden! Sonst teilen sich dev & prod das ES-Datadir.
DB_DATA_PATH=/srv/config/rookhub-dev/mariadb-data
ES_DATA_PATH=/srv/config/rookhub-dev/elasticsearch-data
INIT_DB_PATH=./init-db.sh

# VPN (Gluetun / WireGuard)
VPN_SERVICE_PROVIDER=airvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your_private_key_here
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=10.x.x.x/32
SERVER_COUNTRIES=Germany
FIREWALL_VPN_INPUT_PORTS=8080
