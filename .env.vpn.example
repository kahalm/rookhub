# RookHub VPN/Production Environment
# docker compose -f compose.vpn.yml --env-file .env.vpn up --build

# Database (in Produktion unbedingt aendern!)
MARIADB_ROOT_PASSWORD=change_me
CRAWLER_DB_NAME=chessresults
CRAWLER_DB_USER=chessresults
CRAWLER_DB_PASSWORD=change_me
ROOKHUB_DB_NAME=rookhub
ROOKHUB_DB_USER=rookhub
ROOKHUB_DB_PASSWORD=change_me
DB_EXTERNAL_PORT=3307      # ggf. entfernen oder Firewall-Regel setzen

# JWT (in Produktion unbedingt aendern!)
JWT_KEY=change_me_to_a_secure_key_at_least_32_chars
JWT_ISSUER=RookHub
JWT_AUDIENCE=RookHub

# Admin-Account (wird beim Start angelegt/aktualisiert)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Crawler API Key (schuetzt Crawler-Endpoints, gleicher Wert in Crawler + RookHub API)
CRAWLER_API_KEY=change_me_to_a_secure_key

# Chessable-Integration (Backend in piratechess_docker, im Docker-Netz chessable-bridge).
# CHESSABLE_API_URL: interne URL der piratechess-API.
# CHESSABLE_SERVICE_KEY: MUSS exakt mit SERVICE_API_KEY aus piratechess_docker/.env uebereinstimmen.
# ENCRYPTION_KEY: 32-Byte-Key, mit dem der per-User Chessable-Bearer AES-verschluesselt
# in der rookhub-DB liegt. Aenderung macht alle bestehenden Bearer unlesbar.
CHESSABLE_API_URL=http://piratechess-api:8080
CHESSABLE_SERVICE_KEY=change_me_must_match_piratechess
ENCRYPTION_KEY=change_me_exactly_32_chars_long_!

# Optional: Claude-API-Key fuer die Buch-Puzzle-Tipp-Generierung (nur beim Import/Reprocess).
# Leer lassen = Feature inaktiv. Schluessel: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: GitHub-PAT (actions:read auf die beteiligten Repos) fuer den Admin-Tab "CI / Actions".
# Leer lassen -> Tab zeigt nur einen Hinweis. Fine-grained PAT empfohlen.
GITHUB_TOKEN=

# Discord-Verknuepfung: HMAC-Secret fuer signierte Link-Tokens. MUSS exakt mit dem
# schach-bot (ROOKHUB_LINK_SECRET) uebereinstimmen. Leer lassen -> Feature inaktiv.
DISCORD_LINK_SECRET=change_me_shared_with_schach_bot

# Schach-Bot Stats-Endpoint (/api/bot/player-progress): HMAC-Secret, mit dem der Bot
# den Trainings-/Puzzle-Fortschritt verknuepfter Spieler fuer den Motivations-DM liest.
# MUSS exakt mit dem schach-bot (ROOKHUB_STATS_SECRET) uebereinstimmen. Leer -> Endpoint aus.
SCHACH_BOT_STATS_SECRET=change_me_shared_with_schach_bot

# Basis-URL des Frontends — fuer absolute Links in E-Mails (z.B. Passwort-Reset).
# In Produktion auf die oeffentliche Adresse setzen.
APP_BASE_URL=https://rookhub.oberschmid.homes

# E-Mail-Versand (Passwort-Reset). EMAIL_SMTP_HOST leer lassen -> Versand deaktiviert
# (die Mail inkl. Reset-Link wird dann nur ins Log geschrieben). Fuer echten Versand
# einen SMTP-Server hinterlegen. Port 587 = Submission + STARTTLS (empfohlen),
# 25 nur als Fallback, 465 = implizites SSL.
EMAIL_SMTP_HOST=login.trellmor.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=rookhub@oberschmid.homes
EMAIL_SMTP_PASSWORD=change_me_smtp_password
EMAIL_FROM_ADDRESS=rookhub@oberschmid.homes
EMAIL_FROM_NAME=RookHub
EMAIL_USE_STARTTLS=true

# App
ASPNETCORE_ENVIRONMENT=Production

# Ports
API_PORT=5001
FRONTEND_PORT=8086

# VPN (Gluetun / WireGuard)
VPN_SERVICE_PROVIDER=airvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your_private_key_here
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=10.x.x.x/32
SERVER_COUNTRIES=Germany
FIREWALL_VPN_INPUT_PORTS=8080

# Elasticsearch + Kibana
ES_PORT=9202
KIBANA_PORT=5601
# Admin-UI: Link zur passenden Kibana/ES-Konsole DIESER Umgebung (Admin-Header).
# Leer lassen -> Link bleibt versteckt. Prod-Kibana:
KIBANA_URL=http://10.24.13.6:5601
