# RookHub VPN/Production Environment
# docker compose -f compose.vpn.yml --env-file .env.vpn up --build

# Database (in Produktion unbedingt aendern!)
MARIADB_ROOT_PASSWORD=change_me
CRAWLER_DB_NAME=chessresults
CRAWLER_DB_USER=chessresults
CRAWLER_DB_PASSWORD=change_me
ROOKHUB_DB_NAME=rookhub
ROOKHUB_DB_USER=rookhub
ROOKHUB_DB_PASSWORD=change_me
DB_EXTERNAL_PORT=3307      # ggf. entfernen oder Firewall-Regel setzen

# JWT (in Produktion unbedingt aendern!)
JWT_KEY=change_me_to_a_secure_key_at_least_32_chars
JWT_ISSUER=RookHub
JWT_AUDIENCE=RookHub

# Admin-Account (wird beim Start angelegt/aktualisiert)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Crawler API Key (schuetzt Crawler-Endpoints, gleicher Wert in Crawler + RookHub API)
CRAWLER_API_KEY=change_me_to_a_secure_key

# Discord-Verknuepfung: HMAC-Secret fuer signierte Link-Tokens. MUSS exakt mit dem
# schach-bot (ROOKHUB_LINK_SECRET) uebereinstimmen. Leer lassen -> Feature inaktiv.
DISCORD_LINK_SECRET=change_me_shared_with_schach_bot

# App
ASPNETCORE_ENVIRONMENT=Production

# Ports
API_PORT=5001
FRONTEND_PORT=8085

# VPN (Gluetun / WireGuard)
VPN_SERVICE_PROVIDER=airvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your_private_key_here
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=10.x.x.x/32
SERVER_COUNTRIES=Germany
FIREWALL_VPN_INPUT_PORTS=8080

# Elasticsearch + Kibana
ES_PORT=9200
KIBANA_PORT=5601
