    "help": {
      "title": "Endless Puzzle Mode",
      "gameplayHeading": "How it works",
      "gameplayP1": "You solve chess puzzles of increasing difficulty. You start at a configurable rating and work your way up. The rating rises automatically along the Fasttrack phases (see below).",
      "gameplayP2": "You have <strong>3 lives</strong>. At 0 lives the game is over.",
      "movesHeading": "Moves & Stockfish",
      "movesP1": "Each puzzle has an <strong>intended solution</strong> (a sequence of moves). As long as you play the right moves, you follow that solution line.",
