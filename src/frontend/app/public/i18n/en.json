      "movesItem2": "<strong>Stockfish checkmates you</strong> — you lose a life",
      "movesItem3": "The game against Stockfish continues endlessly until checkmate or Give Up",
      "buttonsHeading": "Buttons during the game",
      "buttonsShowEval": "<strong>Show Eval</strong> — Shows the Stockfish evaluation (Start vs. Now)",
      "buttonsReset": "<strong>Reset</strong> — Resets the puzzle, but costs a life",
      "buttonsMouseslip": "<strong>Mouseslip</strong> — Undoes the last wrong move (once per puzzle, free)",
